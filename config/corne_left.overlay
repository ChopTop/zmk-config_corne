/ {
    chosen {
        zmk,display = &oled;
        zmk,backlight = &backlight;
        zmk,underglow = &underglow;
    };

    backlight: backlight {
        compatible = "zmk,backlight-gpio";

        led0 { gpios = <&gpio0 6 GPIO_ACTIVE_HIGH>; };
        led1 { gpios = <&gpio0 6 GPIO_ACTIVE_HIGH>; };
        led2 { gpios = <&gpio0 6 GPIO_ACTIVE_HIGH>; };
        led3 { gpios = <&gpio0 6 GPIO_ACTIVE_HIGH>; };
        led4 { gpios = <&gpio0 6 GPIO_ACTIVE_HIGH>; };
        led5 { gpios = <&gpio0 6 GPIO_ACTIVE_HIGH>; };
    };

    underglow: underglow {
        compatible = "zmk,rgb-underglow";
        chain-length = <21>;
    };
};

&i2c0 {
    status = "okay";

    oled: ssd1306@3c {
        compatible = "solomon,ssd1306fb";
        reg = <0x3c>;
        width = <128>;
        height = <32>;
    };
};